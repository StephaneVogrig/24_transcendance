# Configuration Auth0
# Remplacez ces valeurs par vos vraies informations Auth0

# Votre domaine Auth0 (exemple: dev-abc123.eu.auth0.com)
VITE_AUTH0_DOMAIN=dev-transcendance.eu.auth0.com

# Votre Client ID Auth0
VITE_AUTH0_CLIENT_ID=your-auth0-client-id-here

# URL de votre application (pour le callback)
VITE_APP_URL=http://localhost:8080
